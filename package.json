{
  "name": "clip-pipeline",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "bun --hot src/index.ts",
    "dev:client": "bun build ./src/index.html --outdir=dist/public --watch",
    "dev": "bun run dev:server & bun run dev:client",
    "build": "bun build ./src/index.html --outdir=dist/public --minify --target=browser",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/google": "^3.0.73",
    "@google/generative-ai": "^0.24.0",
    "ai": "^6.0.182",
    "dotenv": "^17.4.2",
    "execa": "^9.4.1",
    "express": "^4.21.2",
    "groq-sdk": "^0.9.1",
    "multer": "^1.4.5-lts.1",
    "p-queue": "^8.0.1",
    "react": "^19",
    "react-dom": "^19",
    "uuid": "^11.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0"
  }
}
